{
  "name": "hocuspocus",
  "version": "1.0.0",
  "description": "Hocuspocus server with SQLite persistence and REST API",
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch ./src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "backup": "tsx ./src/extensions/backup.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@hocuspocus/extension-logger": "^4.0.0",
    "@hocuspocus/extension-sqlite": "^4.0.0",
    "@hocuspocus/server": "^4.0.0",
    "crossws": "^0.4.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
